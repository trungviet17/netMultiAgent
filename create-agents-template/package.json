{
  "name": "inkeep-agents-quickstart",
  "version": "0.1.0",
  "description": "An Inkeep Agent Framework directory",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "mprocs",
    "dev:all": "concurrently \"turbo dev --filter agents-api-quickstart --filter mcp-quickstart\" \"inkeep dev\" \"wait-on http://localhost:3000 && node scripts/show-services.js\" --names \"API,Dashboard,Info\" --prefix-colors \"blue,green,magenta\" --success first",
    "dev:api": "turbo dev --filter agents-api-quickstart",
    "dev:ui": "inkeep dev",
    "dev:mcp": "turbo dev --filter mcp-quickstart",
    "knip": "knip --directory . --dependencies",
    "db:migrate": "pnpm db:manage:migrate && pnpm db:run:migrate",
    "db:drop": "tsx scripts/db-drop.ts",
    "db:manage:migrate": "tsx scripts/migrate-dolt.ts",
    "db:run:migrate": "drizzle-kit migrate --config=drizzle.run.config.ts",
    "upgrade-agents": "node --experimental-strip-types scripts/upgrade.ts",
    "postinstall": "node --experimental-strip-types scripts/postinstall.ts",
    "setup-dev": "node scripts/setup.js",
    "setup-dev:cloud": "node scripts/setup.js --cloud",
    "setup-dev:optional": "sh scripts/setup-optional.sh",
    "optional:stop": "sh scripts/setup-optional.sh --stop",
    "optional:status": "sh scripts/setup-optional.sh --status",
    "optional:reset": "sh scripts/setup-optional.sh --reset",
    "generate-jwt-keys": "bash scripts/generate-jwt-keys.sh",
    "db:auth:init": "node node_modules/@inkeep/agents-core/dist/auth/init.js"
  },
  "dependencies": {
    "@inkeep/agents-core": "^0.75.4",
    "@inkeep/agents-manage-ui": "^0.75.4",
    "@inkeep/agents-sdk": "^0.75.4",
    "@tailwindcss/vite": "^4.1.14",
    "dotenv": "^17.2.3",
    "tailwindcss": "^4.1.14",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@inkeep/agents-cli": "^0.75.4",
    "@types/node": "^22.13.14",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.44.4",
    "knip": "^5.82.0",
    "mprocs": "^0.7.3",
    "pg": "^8.16.3",
    "tsx": "^4.19.0",
    "turbo": "^2.5.5"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "@hono/node-server": ">=1.19.13",
      "@modelcontextprotocol/sdk": ">=1.26.0",
      "@workflow/core": ">=4.2.0-beta.64",
      "dompurify": ">=3.4.0",
      "fast-xml-parser": ">=5.7.0",
      "serialize-javascript": ">=7.0.5",
      "svgo": ">=3.3.3",
      "minimatch": ">=5.1.8",
      "lodash": ">=4.18.0",
      "lodash-es": ">=4.18.0",
      "express-rate-limit": ">=8.2.2",
      "axios": ">=1.15.2",
      "@xmldom/xmldom": ">=0.8.13",
      "protobufjs": ">=7.5.6 <8 || >=8.0.2",
      "defu": ">=6.1.5",
      "flatted": ">=3.4.2",
      "kysely": ">=0.28.17 <0.29.0",
      "kysely@>=0.29.0": "0.28.17",
      "node-forge": ">=1.4.0",
      "rollup": ">=4.59.0",
      "tar": ">=7.5.11",
      "undici": ">=6.24.0",
      "next": "^16.2.6",
      "qs": ">=6.14.2",
      "devalue": ">=5.6.3",
      "@babel/plugin-transform-modules-systemjs": ">=7.29.4",
      "@opentelemetry/auto-instrumentations-node": ">=0.75.0",
      "@opentelemetry/sdk-node": ">=0.217.0",
      "@opentelemetry/exporter-prometheus": ">=0.217.0",
      "systeminformation": ">=5.31.6",
      "fast-uri": ">=3.1.2",
      "fast-xml-builder": ">=1.1.7",
      "mermaid": ">=11.15.0",
      "uuid": ">=13.0.1",
      "file-type": "21.3.2",
      "nodemailer": "8.0.5",
      "@protobufjs/utf8": ">=1.1.1",
      "ip-address": ">=10.1.1",
      "postcss": ">=8.5.10",
      "follow-redirects": ">=1.16.0",
      "@nestjs/core": ">=11.1.18",
      "yaml": ">=2.8.3",
      "brace-expansion": ">=5.0.5",
      "ajv@>=6 <6.14.0": ">=6.14.0 <7",
      "ajv@>=8 <8.18.0": ">=8.18.0",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=9 <9.0.6": ">=9.0.6",
      "minimatch@>=10 <10.2.1": ">=10.2.1",
      "undici@>=7 <7.24.0": ">=7.24.0",
      "path-to-regexp@<0.1.13": "0.1.13",
      "path-to-regexp@>=4 <6.3.0": "6.3.0",
      "path-to-regexp@>=8 <8.4.0": "8.4.2",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4 <4.0.4": ">=4.0.4"
    }
  }
}
